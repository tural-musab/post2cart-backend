NODE_ENV=production
PORT=3100

# SUPABASE INTEGRATION
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# SECURITY (AES-256-GCM)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
N8N_INTERNAL_TOKEN=change_this_internal_token
OAUTH_STATE_SIGNING_KEY=change_this_state_signing_key_min_32_chars

# MINIO
MINIO_ENDPOINT=post2cart-minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=change_this_access_key
MINIO_SECRET_KEY=change_this_secret_key
MINIO_BUCKET_NAME=post2cart-media
MINIO_PUBLIC_BASE_URL=https://media.post2cart.com

# PUBLIC URLs
PUBLIC_STORE_BASE_URL=https://post2cart.com
FRONTEND_BASE_URL=https://post2cart.com

# META/INSTAGRAM
META_GRAPH_API_VERSION=v20.0
TOKEN_REFRESH_LOOKAHEAD_HOURS=168
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=https://api.post2cart.com/api/v1/app/social/instagram/oauth/callback
META_OAUTH_SCOPES=instagram_basic,instagram_manage_comments,pages_show_list,pages_read_engagement
