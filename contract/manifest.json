{
  "version": "1.3.0",
  "description": "Post2Cart Single Source of Truth API Manifest",
  "services": {
    "syncState": {
      "baseUrl": "/n8n/sync-state",
      "endpoints": {
        "active": {
          "method": "GET",
          "path": "/active",
          "description": "n8n master workflow fetches active sync states.",
          "responses": {
            "200": {
              "sync_state_id": "string",
              "tenant_id": "string",
              "social_account_id": "string",
              "platform": "string",
              "platform_account_id": "string",
              "last_cursor_id": "string|null",
              "decrypted_access_token": "string"
            }
          }
        },
        "updateCursor": {
          "method": "POST",
          "path": "/update-cursor",
          "requestBody": {
            "sync_state_id": "string",
            "last_cursor_id": "string"
          },
          "responses": {
            "200": {
              "status": "updated",
              "sync_state_id": "string",
              "last_cursor_id": "string",
              "last_synced_at": "string",
              "updated_at": "string"
            }
          }
        }
      }
    },
    "webhooks": {
      "baseUrl": "/api/v1/webhooks",
      "endpoints": {
        "socialPost": {
          "method": "POST",
          "path": "/social-posts",
          "description": "n8n pushes fetched social posts.",
          "requestBody": {
            "tenant_id": "string",
            "social_account_id": "string|null",
            "platform": "string",
            "platform_post_id": "string",
            "content": "object"
          },
          "responses": {
            "200": {
              "status": "inserted|duplicate",
              "id": "string"
            }
          }
        },
        "failedItems": {
          "method": "POST",
          "path": "/failed-items",
          "description": "n8n logs failed workflow items.",
          "requestBody": {
            "tenant_id": "string",
            "workflow_name": "string",
            "node_name": "string|null",
            "payload": "object",
            "error_reason": "string",
            "retry_count": "number"
          },
          "responses": {
            "200": {
              "status": "logged",
              "id": "string"
            }
          }
        }
      }
    },
    "media": {
      "baseUrl": "/api/v1/media",
      "endpoints": {
        "processVideo": {
          "method": "POST",
          "path": "/process-video",
          "description": "Asynchronous video processing with n8n callback.",
          "requestBody": {
            "tenant_id": "string",
            "platform_post_id": "string",
            "media_url": "string",
            "n8n_callback_url": "string",
            "payload": "object"
          },
          "responses": {
            "202": {
              "status": "accepted",
              "platform_post_id": "string"
            }
          }
        }
      }
    },
    "products": {
      "baseUrl": "/api/v1/products",
      "endpoints": {
        "draft": {
          "method": "POST",
          "path": "/draft",
          "description": "Create AI-generated draft product.",
          "requestBody": {
            "tenant_id": "string",
            "source_post_id": "string",
            "title": "string",
            "price": "number",
            "ai_metadata": "object",
            "media_urls": "string[]"
          },
          "responses": {
            "200": {
              "status": "success",
              "product_id": "string"
            }
          }
        }
      }
    },
    "social": {
      "baseUrl": "/api/v1/social/instagram",
      "endpoints": {
        "commentProductLink": {
          "method": "POST",
          "path": "/comment-product-link",
          "description": "Posts product link comment to the Instagram source media.",
          "requestBody": {
            "tenant_id": "string",
            "product_id": "string",
            "comment_template": "string"
          },
          "responses": {
            "200": {
              "status": "success",
              "graph_comment_id": "string|null"
            }
          }
        }
      }
    },
    "appClient": {
      "baseUrl": "/api/v1/app",
      "endpoints": {
        "bootstrap": {
          "method": "GET",
          "path": "/bootstrap",
          "description": "Returns user + tenant + onboarding readiness snapshot for frontend app shell."
        },
        "createTenant": {
          "method": "POST",
          "path": "/tenants",
          "requestBody": {
            "name": "string"
          },
          "responses": {
            "200": {
              "status": "success",
              "tenant": {
                "id": "string",
                "name": "string"
              }
            }
          }
        },
        "onboardingStatus": {
          "method": "GET",
          "path": "/onboarding/status",
          "responses": {
            "200": {
              "has_tenant": "boolean",
              "has_social_account": "boolean",
              "has_sync_state": "boolean",
              "token_valid": "boolean",
              "automation_ready": "boolean"
            }
          }
        },
        "manualInstagramConnect": {
          "method": "POST",
          "path": "/social-accounts/instagram/manual",
          "requestBody": {
            "platform_account_id": "string",
            "platform_username": "string|null",
            "access_token": "string",
            "token_expires_at": "string|null"
          }
        },
        "products": {
          "method": "GET",
          "path": "/products"
        },
        "publishProduct": {
          "method": "PATCH",
          "path": "/products/:id/publish",
          "requestBody": {
            "price": "number"
          }
        },
        "oauthStart": {
          "method": "GET",
          "path": "/social/instagram/oauth/start",
          "description": "Phase-2 OAuth authorization URL generation endpoint."
        },
        "oauthCallback": {
          "method": "GET",
          "path": "/social/instagram/oauth/callback",
          "description": "Phase-2 OAuth callback endpoint with real code exchange and onboarding redirects."
        },
        "oauthPending": {
          "method": "GET",
          "path": "/social/instagram/oauth/pending/:sessionId",
          "description": "Returns candidate Instagram business accounts for pending selection sessions."
        },
        "oauthFinalize": {
          "method": "POST",
          "path": "/social/instagram/oauth/finalize",
          "requestBody": {
            "session_id": "string",
            "platform_account_id": "string"
          },
          "description": "Finalizes selected Instagram account and persists social_accounts + sync_state."
        }
      }
    }
  }
}
